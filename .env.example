# Ada Bereket Kurban — Çevre Değişkenleri Örneği
# Bu dosyayı .env olarak kopyalayın ve değerleri doldurun.

# SQLite veritabanı yolu
DATABASE_URL="file:./prisma/tilbe.db"

# Iron-session şifreleme anahtarı — MUTLAKA KENDİ DEĞERİNİZİ ÜRETİN
# Üretmek için (terminal):
#   openssl rand -base64 48
# veya:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
# Boş bırakırsanız sistem başlamaz (en az 32 karakter zorunlu).
SESSION_SECRET=

# Admin ilk kurulum şifresi — sadece "pnpm db:seed" çalıştırılırken kullanılır.
# Min 12 karakter zorunlu. İlk girişten sonra UI'dan değiştirilmelidir.
# Örnek: ADMIN_INITIAL_PASSWORD=Bayram2026!Tilbe
ADMIN_INITIAL_PASSWORD=

# Firma bilgileri (dekontta gösterilir, /ayarlar sayfasından da güncellenebilir)
FIRMA_ADI="Ada Bereket Hayvancılık"
FIRMA_TELEFON="+90 536 390 44 18"
FIRMA_ADRES="Harmantepe, Örgün Sokak No: 24"

# Web Push VAPID (FAZ 9.6 — PWA arka plan bildirim)
# Üretmek için: pnpm tsx scripts/vapid-uret.ts
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@adaberekethayvancilik.com.tr
NEXT_PUBLIC_VAPID_PUBLIC_KEY=

# HTTPS production'da: SESSION_SECURE=true (LAN HTTP'de boş bırak)
SESSION_SECURE=

# Dekont doğrulama HMAC secret — sahte dekont üretimine karşı koruma.
# En az 32 karakter zorunlu (server boot'ta kontrol edilir).
# Üretmek için:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Bu değer DEĞİŞTİRİLDİĞİNDE üretilmiş eski dekont doğrulama kodları geçersizleşir.
DEKONT_DOGRULAMA_SECRET=
