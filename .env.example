# Tilbe Kurban - Çevre Değişkenleri Örneği
# Bu dosyayı .env olarak kopyalayın ve değerleri güncelleyin

# SQLite veritabanı yolu
DATABASE_URL="file:./tilbe.db"

# Iron-session şifreleme anahtarı (EN AZ 32 KARAKTER, production'da değiştirin)
SESSION_SECRET="degistirin-bu-secret-en-az-32-karakter-uzunluk-olmali-2026"

# Firma bilgileri (dekontta gösterilir, /ayarlar sayfasından da güncellenebilir)
FIRMA_ADI="Tilbe Kurban"
FIRMA_TELEFON="0530 889 54 34"
FIRMA_ADRES="Sakarya / Serdivan"

# Web Push VAPID (FAZ 9.6 — PWA arka plan bildirim)
# Üretmek için: pnpm tsx scripts/vapid-uret.ts
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@tilbehome.com
NEXT_PUBLIC_VAPID_PUBLIC_KEY=

# HTTPS production'da: SESSION_SECURE=true (LAN HTTP'de bos birak)
SESSION_SECURE=
