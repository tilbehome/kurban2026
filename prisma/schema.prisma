// Tilbe Kurban — Prisma Schema (MIMARI.md §5 uyumlu)
//
// Standartlar:
//  - ID: String @id @default(cuid())
//  - Tüm modellerde: silindiMi, silinmeTarihi, olusturanId, createdAt, updatedAt
//  - Soft delete: kayıt fiziksel silinmez, silindiMi=true yapılır
//  - Audit log: AuditLog tablosu tüm kritik işlemleri saklar
//  - İndeksler: sık sorgulanan + silindiMi alanı

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ===========================================================================
// CORE — Auth, Ayarlar, Modül durumu, Audit
// ===========================================================================

model Kullanici {
  id           String    @id @default(cuid())
  kullaniciAdi String    @unique
  sifreHash    String
  adSoyad      String
  rol          String // "admin" | "kasiyer" | "izleyici"
  gorev        String? // "vekalet" | "kesim" | "tartim" | "paketleme" | "teslim" | null (genel)
  aktif        Boolean   @default(true)
  sonGiris     DateTime?

  // Soft delete + audit
  silindiMi     Boolean   @default(false)
  silinmeTarihi DateTime?
  olusturanId   String?

  // Standart timestamp
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // İlişkiler
  odemeler           Odeme[]
  kasaHareket        KasaHareketi[]
  auditlar           AuditLog[]
  whatsappGonderimleri WhatsAppGonderim[] @relation("WhatsAppGonderen")

  @@index([kullaniciAdi])
  @@index([silindiMi])
}

model Ayar {
  anahtar     String   @id // "firma_adi", "firma_telefon" vb.
  deger       String
  guncelTarih DateTime @default(now())
}

model ModulDurum {
  id          String   @id // modül id'si
  aktif       Boolean  @default(true)
  versiyon    String
  ayarlar     String? // JSON string
  yuklemeT    DateTime @default(now())
  guncelTarih DateTime @updatedAt
}

/// Tüm kritik işlemler için audit log (MIMARI.md §12)
model AuditLog {
  id          String   @id @default(cuid())
  eylem       String // "olustur" | "guncelle" | "sil" | "giris" | "cikis" | "odeme" | "yedek"
  model       String? // Etkilenen model adı: "Musteri", "Odeme" vb.
  kayitId     String? // Etkilenen kayıt ID
  kullaniciId String?
  kullanici   Kullanici? @relation(fields: [kullaniciId], references: [id])
  ip          String?
  detaylar    String? // JSON string (önceki/sonraki değer vb.)
  createdAt   DateTime @default(now())

  @@index([createdAt])
  @@index([eylem])
  @@index([kullaniciId])
  @@index([model, kayitId])
}

// ===========================================================================
// MUSTERILER
// ===========================================================================

model Musteri {
  id        String  @id @default(cuid())
  adSoyad   String
  telefon   String?
  tcKimlik  String?
  adres     String?
  notlar    String?
  etiketler String? // JSON: ["VIP", "Düzenli"]

  // Soft delete + audit
  silindiMi     Boolean   @default(false)
  silinmeTarihi DateTime?
  olusturanId   String?

  // Standart timestamp
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // İlişkiler
  hisseler  Hisse[]
  musteriNotlari Not[]
  pushAbonelikleri PushAbonelik[] @relation("MusteriPushAbonelik")

  @@index([adSoyad])
  @@index([telefon])
  @@index([silindiMi])
}

// ===========================================================================
// HAYVANLAR — Kurban + Hisse
// ===========================================================================

model Kurban {
  id            String   @id @default(cuid())
  kesimSirasi   Int      @unique // Kurban kayıt sırası (DANA-1, DANA-2 ...)
  kesimSaati    String? // "07:10" gibi planlanan saat
  kupeNo        String?
  hisseSayisi   Int      @default(7)
  satisBedeli   Float    @default(0)
  canliAgirlik  Float?   @default(0)
  karkasAgirlik Float?   @default(0)
  durum         String   @default("aktif") // aktif | bekliyor | kesimde | kesildi | parcalandi | teslim | iptal
  notlar        String?

  // Hisse grup notu (sadece bilgi amaçlı, fiyatlandırma yapmaz)
  // "30-35" | "35-40" | "40-45" | "45-50" | "50-55" | null (belirsiz)
  hisseGrubu    String?

  // KESİM TAKİP — KURBAN BAZLI (FAZ 9.5)
  // Tartıma kadar tüm hisseler birlikte hareket eder
  kesimDurumu     String   @default("beklemede") // beklemede|vekalet_bekliyor|siradaki|hazirlik|kesimde|deri_yuzme|parcalama|tartimda|paketleme|teslime_hazir|tamamlandi|iptal
  operasyonSira   Int? // operasyonel sıra (1, 2, 3 ...)
  asama           String? // "Kesim" | "Deri Yüzme" | "Parçalama" | "Tartım"
  ilerlemeYuzde   Int      @default(0) // 0-100
  kalanSureDk     Int?
  kesimBaslama    DateTime?
  kesimBitis      DateTime?
  toplamKg        Float? // tartım sonucu toplam et
  karkasKg        Float? // karkas ağırlığı

  // Soft delete + audit
  silindiMi     Boolean   @default(false)
  silinmeTarihi DateTime?
  olusturanId   String?

  // Standart timestamp
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // İlişkiler
  hisseler Hisse[]

  @@index([kesimSirasi])
  @@index([durum])
  @@index([silindiMi])
  @@index([kesimDurumu])
  @@index([operasyonSira])
  @@index([hisseGrubu])
}

model Hisse {
  id            String    @id @default(cuid())
  kurbanId      String
  kurban        Kurban    @relation(fields: [kurbanId], references: [id], onDelete: Cascade)
  no            Int // 1-7 arası
  musteriId     String?
  musteri       Musteri?  @relation(fields: [musteriId], references: [id])
  hisseFiyati   Float     @default(0)
  vekaletAlindi Boolean   @default(false)
  vekaletTarihi DateTime?
  notlar        String?

  // KESİM TAKİP (FAZ 9 — TV ekranı için, hisse bazlı geçmiş)
  // NOT: Tartıma kadar Kurban.kesimDurumu kullanılır.
  //      Paketleme'den sonra her hisse ayrı (Hisse.paketDurumu).
  kesimDurumu   String    @default("beklemede")
  siraNo        Int? // sıra numarası (1, 2, 3...)
  asama         String? // "Kesim" | "Deri Yüzme" | "Parçalama Hazırlık" | "Parçalama" | "Tartım" | "Paketleme" | "Teslim"
  ilerlemeYuzde Int       @default(0) // 0-100
  kalanSureDk   Int?
  kesimBaslama  DateTime?
  kesimBitis    DateTime?
  teslimNoktasi String? // "Teslim Noktası 1"
  teslimDurumu  String? // "Hazır" | "Teslim Edildi"

  // PAKETLEME + TESLİM (FAZ 9.5 - hisse bazlı, tartım sonrası)
  paketDurumu   String? // "Bekliyor" | "Paketlendi" | "Teslim Hazır" | "Teslim Edildi"
  paketKg       Float? // Bu hisseye düşen et kg
  teslimTarihi  DateTime?

  // Soft delete + audit
  silindiMi     Boolean   @default(false)
  silinmeTarihi DateTime?
  olusturanId   String?

  // Standart timestamp
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // İlişkiler
  odemeler Odeme[]
  vekalet  Vekalet?

  @@unique([kurbanId, no])
  @@index([musteriId])
  @@index([silindiMi])
  @@index([kesimDurumu])
  @@index([siraNo])
  @@index([paketDurumu])
}

// ===========================================================================
// NOT (müşteri notları)
// ===========================================================================

model Not {
  id          String  @id @default(cuid())
  musteriId   String
  musteri     Musteri @relation(fields: [musteriId], references: [id], onDelete: Cascade)

  icerik       String // max 1000 char
  renk         String  @default("bilgi") // bilgi | uyari | onemli | hatirlat
  sabitlendiMi Boolean @default(false)

  // Soft delete + audit
  olusturanId   String
  silindiMi     Boolean   @default(false)
  silinmeTarihi DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([musteriId])
  @@index([silindiMi])
  @@index([renk])
}

// ===========================================================================
// VEKALET (hisse başına bir belge)
// ===========================================================================

model Vekalet {
  id      String @id @default(cuid())
  hisseId String @unique
  hisse   Hisse  @relation(fields: [hisseId], references: [id], onDelete: Cascade)

  dosyaUrl    String // /uploads/vekalet/<cuid>.pdf
  dosyaTipi   String // pdf | jpg | png
  dosyaBoyutu Int // bytes

  // Soft delete + audit
  olusturanId   String
  silindiMi     Boolean   @default(false)
  silinmeTarihi DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([silindiMi])
}

// ===========================================================================
// TAHSILAT — Ödeme
// ===========================================================================

model Odeme {
  id          String    @id @default(cuid())
  hisseId     String
  hisse       Hisse     @relation(fields: [hisseId], references: [id], onDelete: Cascade)
  tarih       DateTime  @default(now())
  nakit       Float     @default(0)
  havale      Float     @default(0)
  kart        Float     @default(0)
  toplamTutar Float
  yontem      String // "nakit" | "havale" | "kart" | "karisik"
  notlar      String?
  dekontNo    String    @unique // "TKR-2026-000001"
  kullaniciId String
  kullanici   Kullanici @relation(fields: [kullaniciId], references: [id])

  // İptal alanları (Odeme için özel)
  iptal       Boolean   @default(false)
  iptalSebep  String?
  iptalTarihi DateTime?
  iptalKulId  String?

  // Soft delete + audit (Odeme'ler genelde iptal yapılır, silinmez ama yine de standart)
  silindiMi     Boolean   @default(false)
  silinmeTarihi DateTime?
  olusturanId   String?

  // Standart timestamp
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([hisseId])
  @@index([tarih])
  @@index([dekontNo])
  @@index([silindiMi])
  @@index([iptal])
}

// ===========================================================================
// KASA
// ===========================================================================

model KasaHareketi {
  id          String    @id @default(cuid())
  tip         String // "tahsilat" | "gider" | "acilis" | "kapanis"
  tutar       Float
  yontem      String // "nakit" | "havale" | "kart"
  aciklama    String
  odemeId     String?
  kullaniciId String
  kullanici   Kullanici @relation(fields: [kullaniciId], references: [id])
  tarih       DateTime  @default(now())

  // Soft delete + audit
  silindiMi     Boolean   @default(false)
  silinmeTarihi DateTime?
  olusturanId   String?

  // Standart timestamp
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tarih])
  @@index([tip])
  @@index([silindiMi])
}

// ===========================================================================
// WHATSAPP — FAZ 8
// ===========================================================================

model WhatsAppSablonu {
  id         String  @id @default(cuid())
  ad         String
  kategori   String // "tahsilat" | "bayram" | "kesim" | "genel"
  icerik     String // metin + {degisken}
  aktifMi    Boolean @default(true)
  varsayilan Boolean @default(false) // sistem şablonu, silinemez

  // Audit
  olusturanId   String?
  silindiMi     Boolean   @default(false)
  silinmeTarihi DateTime?

  // Standart timestamp
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  gonderilenler WhatsAppGonderim[]

  @@index([aktifMi, silindiMi])
  @@index([kategori])
}

model WhatsAppGonderim {
  id       String          @id @default(cuid())
  sablonId String
  sablon   WhatsAppSablonu @relation(fields: [sablonId], references: [id])

  baslamaTarihi DateTime  @default(now())
  bitisTarihi   DateTime?

  hedefSayisi    Int @default(0)
  acilanSayisi   Int @default(0)
  atlananSayisi  Int @default(0)
  hataSayisi     Int @default(0)
  telefonsuzSayisi Int @default(0)

  not String?

  // Hedeflenen müşteriler (JSON dizi)
  // [{musteriId, musteriAdSoyad, telefon, durum, acilmaZamani}]
  hedefler String

  // Audit
  kullaniciId   String
  kullanici     Kullanici @relation("WhatsAppGonderen", fields: [kullaniciId], references: [id])
  silindiMi     Boolean   @default(false)
  silinmeTarihi DateTime?
  olusturanId   String?

  // Standart timestamp
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([sablonId])
  @@index([kullaniciId])
  @@index([silindiMi])
  @@index([baslamaTarihi])
}

// ===========================================================================
// TV AYARI — FAZ 9 (alt bilgi şeritleri ve TV genel ayarları)
// ===========================================================================

model TvAyari {
  id            String   @id @default(cuid())
  anahtarKey    String   @unique // "duyuru" | "sira_hatirlatma" | "hijyen" | "whatsapp_tel" | "lokasyon"
  deger         String // metin içeriği
  aktif         Boolean  @default(true)
  guncelleyenId String?

  // Standart timestamp
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([aktif])
}

// ===========================================================================
// PUSH ABONELİK — FAZ 9.5 (browser push notifications)
// ===========================================================================

model PushAbonelik {
  id        String   @id @default(cuid())
  musteriId String?
  musteri   Musteri? @relation("MusteriPushAbonelik", fields: [musteriId], references: [id])
  // PushSubscription endpoint (Web Push API)
  endpoint  String   @unique
  p256dh    String // ECDH public key
  auth      String // shared auth secret
  // Anonim oturum için (giriş yapmadan dana takip eden müşteri)
  oturumKey String? // örn: kurbanId veya geçici kod
  aktif     Boolean  @default(true)
  // Cihaz tanımı (debugging için)
  userAgent String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  bildirimler BildirimLog[]

  @@index([musteriId])
  @@index([oturumKey])
  @@index([aktif])
}

// ===========================================================================
// BİLDİRİM LOG — FAZ 9.5 (her gönderim kayıtlı)
// ===========================================================================

model BildirimLog {
  id           String   @id @default(cuid())
  musteriId    String?
  abonelikId   String?
  abonelik     PushAbonelik? @relation(fields: [abonelikId], references: [id])
  kullaniciId  String? // Bildirimi gönderen kullanıcı (audit için)
  kanal        String // "push" | "whatsapp" | "sesli" | "sms"
  sablon       String? // "kesim_basladi" | "tartim_basladi" | "paket_hazir" | "sira_yaklasti" vs
  baslik       String
  mesaj        String
  durum        String   @default("gonderildi") // "gonderildi" | "hata" | "okundu"
  hata         String?

  createdAt DateTime @default(now())

  @@index([musteriId])
  @@index([kanal])
  @@index([createdAt])
  @@index([kullaniciId])
}
